{
  "name": "audio-finder",
  "version": "1.0.0",
  "description": "Extract and download audio from public video links",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o node_modules/yt-dlp-exec/bin/yt-dlp && chmod +x node_modules/yt-dlp-exec/bin/yt-dlp || true",
    "postinstall": "node -e \"try{require('yt-dlp-exec')}catch(e){}\"",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
